{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "interactable.schema.json",
  "title": "Interactable",
  "description": "Definition of an interactable object type",
  "type": "object",
  "required": ["type_id", "display_name", "category", "interactions"],
  "properties": {
    "type_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "display_name": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": ["nature", "structure", "mechanism", "container", "npc", "collectible", "traversal", "puzzle"]
    },
    "sprite_base": {
      "type": "string",
      "description": "Base path for sprite assets"
    },
    "size": {
      "type": "object",
      "properties": {
        "width": { "type": "integer", "minimum": 8 },
        "height": { "type": "integer", "minimum": 8 }
      }
    },
    "interactions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action", "result"],
        "properties": {
          "action": {
            "type": "string",
            "enum": ["interact", "climb", "push", "harvest", "activate", "open", "read", "solve", "collect"]
          },
          "result": {
            "type": "string",
            "enum": ["trigger_task", "give_item", "change_state", "play_animation", "open_path", "show_dialogue", "add_collectible", "env_change"]
          },
          "requires": {
            "type": "object",
            "properties": {
              "item": { "type": "string" },
              "skill_level": { "type": "integer" },
              "task_complete": { "type": "string" },
              "traversal": { "type": "string" }
            }
          }
        }
      },
      "minItems": 1
    },
    "states": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["state_name", "sprite_variant"],
        "properties": {
          "state_name": { "type": "string" },
          "sprite_variant": { "type": "string" },
          "physics": { "type": "string", "enum": ["static", "rigid", "kinematic", "area"] }
        }
      }
    },
    "has_proximity_animation": {
      "type": "boolean",
      "default": true
    },
    "interact_radius": {
      "type": "number",
      "minimum": 8,
      "default": 32
    },
    "prompt_text": {
      "type": "string",
      "description": "Text shown when player is nearby"
    }
  },
  "additionalProperties": false
}
